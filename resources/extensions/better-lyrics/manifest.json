{
  "manifest_version": 3,
  "version": "2.2.0",
  "default_locale": "en",
  "name": "Better Lyrics (Lyrics for Youtube Music)",
  "description": "__MSG_extensionDescription__",
  "homepage_url": "https://better-lyrics.boidu.dev",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "512": "icons/icon-512.png"
  },
  "host_permissions": [
    "*://music.youtube.com/*"
  ],
  "permissions": [
    "storage",
    "alarms"
  ],
  "optional_permissions": [
    "downloads"
  ],
  "optional_host_permissions": [
    "https://raw.githubusercontent.com/better-lyrics/themes/*",
    "https://better-lyrics-themes-api.boidu.dev/*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "options_ui": {
    "page": "options_ui/page.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": [
        "*.js.map",
        "css/blyrics/*.css",
        "css/disablestylizedanimations.css",
        "css/themes/*.css",
        "css/themesong.css",
        "css/ytmusic/*.css",
        "pages/marketplace.html",
        "pages/standalone-editor.html"
      ],
      "matches": [
        "*://music.youtube.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "betterlyrics@boidu.dev",
      "strict_min_version": "100.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://music.youtube.com/*"
      ],
      "js": [
        "content_scripts/content-0.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED",
      "css": []
    },
    {
      "matches": [
        "*://music.youtube.com/*"
      ],
      "js": [
        "earlyInject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "css": []
    },
    {
      "matches": [
        "*://music.youtube.com/*"
      ],
      "js": [
        "script.js"
      ],
      "run_at": "document_end",
      "world": "MAIN",
      "css": []
    }
  ],
  "action": {
    "default_popup": "action/default_popup.html"
  },
  "version_name": "2.2.0",
  "key": "",
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "update_url": "https://clients2.google.com/service/update2/crx"
}